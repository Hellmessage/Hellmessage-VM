+// 注册成 EFI_RESOURCE_SYSTEM_MEMORY + 加 MMU 页表.
+//
+typedef struct {
+  UINT64    Base;
+  UINT64    Size;
+} HVM_EXTRA_MEMORY_INFO;
+
