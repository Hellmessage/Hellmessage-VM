diff --git a/ArmVirtPkg/Library/ArmVirtMemoryInitPeiLib/ArmVirtMemoryInitPeiLib.c b/ArmVirtPkg/Library/ArmVirtMemoryInitPeiLib/ArmVirtMemoryInitPeiLib.c
index 72e5c65..f083c03 100644
--- a/ArmVirtPkg/Library/ArmVirtMemoryInitPeiLib/ArmVirtMemoryInitPeiLib.c
+++ b/ArmVirtPkg/Library/ArmVirtMemoryInitPeiLib/ArmVirtMemoryInitPeiLib.c
@@ -99,6 +99,34 @@ MemoryPeim (
       );
   }
 
+  //
+  // HVM: 若 QemuVirtMemInfoPeiLibConstructor 收集到额外 RAM 节点 (Win11 ARM64
+  // bootmgfw 用的 0x10000000 区), 这里也注册成 EFI_RESOURCE_SYSTEM_MEMORY 让 GCD
+  // 知道; 不然 bootmgr 调 ConvertPages 在这块地址会因为 GCD 不识别报错失败.
+  //
+  {
+    typedef struct {
+      UINT64    Base;
+      UINT64    Size;
+    } HVM_EXTRA_MEMORY_INFO;
+    extern EFI_GUID         gHvmExtraMemoryGuid;
+    EFI_PEI_HOB_POINTERS    HvmExtraHob;
+    HVM_EXTRA_MEMORY_INFO   *HvmExtra;
+
+    HvmExtraHob.Raw = GetFirstGuidHob (&gHvmExtraMemoryGuid);
+    if (HvmExtraHob.Raw != NULL) {
+      HvmExtra = (HVM_EXTRA_MEMORY_INFO *)GET_GUID_HOB_DATA (HvmExtraHob.Guid);
+      if (HvmExtra->Size > 0) {
+        BuildResourceDescriptorHob (
+          EFI_RESOURCE_SYSTEM_MEMORY,
+          ResourceAttributes,
+          HvmExtra->Base,
+          HvmExtra->Size
+          );
+      }
+    }
+  }
+
   // Build Memory Allocation Hob
   InitMmu ();
 
