diff --git a/ArmVirtPkg/Library/QemuVirtMemInfoLib/QemuVirtMemInfoLib.c b/ArmVirtPkg/Library/QemuVirtMemInfoLib/QemuVirtMemInfoLib.c
index d435d72..6ff6292 100644
--- a/ArmVirtPkg/Library/QemuVirtMemInfoLib/QemuVirtMemInfoLib.c
+++ b/ArmVirtPkg/Library/QemuVirtMemInfoLib/QemuVirtMemInfoLib.c
@@ -117,6 +117,36 @@ ArmVirtGetMemoryMap (
   VirtualMemoryTable[2].Length       = FixedPcdGet32 (PcdFvSize);
   VirtualMemoryTable[2].Attributes   = ARM_MEMORY_REGION_ATTRIBUTE_WRITE_BACK_RO;
 
+  //
+  // HVM: 若有额外 RAM 节点 (Win11 ARM64 0x10000000), 也加进 MMU 页表;
+  // 否则 bootmgfw 访问这块区域会触发 data abort. MAX_VIRTUAL_MEMORY_MAP_DESCRIPTORS=5
+  // 已经留够空间.
+  //
+  {
+    typedef struct {
+      UINT64    Base;
+      UINT64    Size;
+    } HVM_EXTRA_MEMORY_INFO;
+    extern EFI_GUID         gHvmExtraMemoryGuid;
+    EFI_PEI_HOB_POINTERS    HvmExtraHob;
+    HVM_EXTRA_MEMORY_INFO   *HvmExtra;
+
+    HvmExtraHob.Raw = GetFirstGuidHob (&gHvmExtraMemoryGuid);
+    if (HvmExtraHob.Raw != NULL) {
+      HvmExtra = (HVM_EXTRA_MEMORY_INFO *)GET_GUID_HOB_DATA (HvmExtraHob.Guid);
+      if (HvmExtra->Size > 0) {
+        VirtualMemoryTable[3].PhysicalBase = HvmExtra->Base;
+        VirtualMemoryTable[3].VirtualBase  = HvmExtra->Base;
+        VirtualMemoryTable[3].Length       = HvmExtra->Size;
+        VirtualMemoryTable[3].Attributes   = ARM_MEMORY_REGION_ATTRIBUTE_WRITE_BACK;
+        // End of Table
+        ZeroMem (&VirtualMemoryTable[4], sizeof (ARM_MEMORY_REGION_DESCRIPTOR));
+        *VirtualMemoryMap = VirtualMemoryTable;
+        return;
+      }
+    }
+  }
+
   // End of Table
   ZeroMem (&VirtualMemoryTable[3], sizeof (ARM_MEMORY_REGION_DESCRIPTOR));
 
