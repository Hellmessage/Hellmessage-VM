+    hw_display_modules += {'hvm-gpu-ramfb-pci': hvm_gpu_ramfb_pci_ss}
+  endif
+
   if virgl.found() and opengl.found()
     virtio_gpu_pci_gl_ss = ss.source_set()
     virtio_gpu_pci_gl_ss.add(when: ['CONFIG_VIRTIO_GPU', 'CONFIG_VIRTIO_PCI', virgl, opengl],
diff --git a/hw/display/ramfb.c b/hw/display/ramfb.c
index 9a17d97..b1f5607 100644
--- a/hw/display/ramfb.c
+++ b/hw/display/ramfb.c
@@ -124,6 +124,15 @@ static int ramfb_post_load(void *opaque, int version_id)
     return 0;
 }
 
+void ramfb_resend_surface(RAMFBState *s)
+{
+    /* Re-run the fw_cfg write callback, which re-creates the display surface
+     * from the cached config. After this, the next ramfb_display_update() call
+     * will dpy_gfx_replace_surface() with a fresh surface, replacing whatever
+     * (e.g. NULL placeholder from virtio-gpu reset) is currently on the console. */
+    ramfb_fw_cfg_write(s, 0, 0);
+}
+
 const VMStateDescription ramfb_vmstate = {
     .name = "ramfb",
     .version_id = 1,
diff --git a/include/hw/display/hvm-gpu-ramfb-pci.h b/include/hw/display/hvm-gpu-ramfb-pci.h
new file mode 100644
index 0000000..43b5b5c
--- /dev/null
+++ b/include/hw/display/hvm-gpu-ramfb-pci.h
@@ -0,0 +1,36 @@
+/*
+ * HVM hybrid display device: virtio-gpu-pci + ramfb fallback
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+
+#ifndef HW_DISPLAY_HVM_GPU_RAMFB_PCI_H
+#define HW_DISPLAY_HVM_GPU_RAMFB_PCI_H
+
+#include "hw/resettable.h"
+#include "hw/virtio/virtio-pci.h"
+#include "hw/virtio/virtio-gpu.h"
+#include "hw/display/ramfb.h"
+#include "qom/object.h"
+
+#define TYPE_HVM_GPU_RAMFB_PCI_BASE "hvm-gpu-ramfb-pci-base"
+#define TYPE_HVM_GPU_RAMFB_PCI      "hvm-gpu-ramfb-pci"
+
+typedef struct HVMGPURamfbBase HVMGPURamfbBase;
+typedef struct HVMGPURamfbBaseClass HVMGPURamfbBaseClass;
+
+DECLARE_OBJ_CHECKERS(HVMGPURamfbBase, HVMGPURamfbBaseClass,
+                     HVM_GPU_RAMFB_PCI_BASE, TYPE_HVM_GPU_RAMFB_PCI_BASE)
+
+struct HVMGPURamfbBase {
+    VirtIOPCIProxy parent_obj;
+    VirtIOGPUBase *vgpu;
+    RAMFBState   *ramfb;
+};
+
+struct HVMGPURamfbBaseClass {
+    VirtioPCIClass parent_class;
+    ResettablePhases parent_phases;
+};
+
+#endif /* HW_DISPLAY_HVM_GPU_RAMFB_PCI_H */
diff --git a/include/hw/display/ramfb.h b/include/hw/display/ramfb.h
index 172aa6d..17fbb71 100644
--- a/include/hw/display/ramfb.h
+++ b/include/hw/display/ramfb.h
@@ -7,6 +7,13 @@
 typedef struct RAMFBState RAMFBState;
 void ramfb_display_update(QemuConsole *con, RAMFBState *s);
 RAMFBState *ramfb_setup(bool romfile, Error **errp);
+/* Re-create the display surface from the cached fw_cfg (etc/ramfb) config,
+ * forcing the next ramfb_display_update() to dpy_gfx_replace_surface() again.
+ * Useful when an external code path (eg virtio-gpu reset) replaced the
+ * console surface with the "Display output is not active" NULL placeholder.
+ * Idempotent if no valid framebuffer config has been written by the guest
+ * yet (s->width == 0). */
+void ramfb_resend_surface(RAMFBState *s);
 
 extern const VMStateDescription ramfb_vmstate;
 
