 # CONFIG_SBSA_REF=n
 # CONFIG_NPCM8XX=n
 CONFIG_VMAPPLE=n
+
+# HVM 自家 device: virtio-ramfb-pci. virtio-gpu-pci + ramfb 同 PCI 设备同 console 双模.
+# Boot 阶段 ramfb GOP 给 EDK2/bootmgfw, viogpudo driver 加载后切 virtio-gpu 渲染,
+# 兼容 patch 0002 IOSurface backend 单 console 限制 + 支持 EDID 动态分辨率.
+CONFIG_VIRTIO_RAMFB=y
