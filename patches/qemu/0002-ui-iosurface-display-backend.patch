diff --git a/include/ui/hvm_display_proto.h b/include/ui/hvm_display_proto.h
new file mode 100644
index 0000000..667d749
--- /dev/null
+++ b/include/ui/hvm_display_proto.h
@@ -0,0 +1,119 @@
+/*
+ * HVM-QEMU display backend protocol (HDP) — version 1.0.0
+ *
+ * AF_UNIX SOCK_STREAM transport, little-endian wire format.
+ * Canonical specification: docs/QEMU_DISPLAY_PROTOCOL.md (in HVM repo).
+ *
+ * This header is the C-side mirror of the spec.  Modifying either side
+ * REQUIRES updating the other, plus appending an entry to §13 of the spec.
+ *
+ * SPDX-License-Identifier: GPL-2.0-or-later
+ */
+#ifndef HVM_DISPLAY_PROTO_H
+#define HVM_DISPLAY_PROTO_H
+
+#include <stdint.h>
+
+/* ---- protocol version -------------------------------------------------- */
+#define HVM_DISP_PROTO_MAJOR  1
+#define HVM_DISP_PROTO_MINOR  0
+#define HVM_DISP_PROTO_PATCH  0
+#define HVM_DISP_PROTO_VERSION                                          \
+    (((uint32_t)HVM_DISP_PROTO_MAJOR << 16) |                           \
+     ((uint32_t)HVM_DISP_PROTO_MINOR <<  8) |                           \
+      (uint32_t)HVM_DISP_PROTO_PATCH)
+
+/* ---- header (8 bytes, little-endian on the wire) ----------------------- */
+struct hvm_disp_hdr {
+    uint16_t type;
+    uint16_t flags;
+    uint32_t payload_len;
+} __attribute__((packed));
+
+/* ---- flags bits (header.flags) ----------------------------------------- */
+#define HVM_DISP_FLAG_HAS_FD   0x0001u  /* SCM_RIGHTS fd attached */
+#define HVM_DISP_FLAG_URGENT   0x0002u  /* delivery hint, optional */
+
+/* ---- capability_flags bits (HELLO payload) ----------------------------- */
+#define HVM_DISP_CAP_CURSOR_BGRA      0x00000001u
+#define HVM_DISP_CAP_LED_STATE        0x00000002u
+#define HVM_DISP_CAP_VDAGENT_RESIZE   0x00000004u
+
+/* ---- pixel formats (SURFACE_NEW.format) -------------------------------- */
+#define HVM_DISP_PIXFMT_BGRA8  0x00000001u
+
+/* ---- message type IDs (header.type) ------------------------------------ */
+enum {
+    HVM_DISP_MSG_HELLO          = 0x0001,
+    HVM_DISP_MSG_SURFACE_NEW    = 0x0002,
+    HVM_DISP_MSG_SURFACE_DAMAGE = 0x0003,
+    HVM_DISP_MSG_CURSOR_DEFINE  = 0x0010,
+    HVM_DISP_MSG_CURSOR_POS     = 0x0011,
+    HVM_DISP_MSG_LED_STATE      = 0x0020,
+    HVM_DISP_MSG_RESIZE_REQUEST = 0x0080,
+    HVM_DISP_MSG_GOODBYE        = 0x00FF,
+};
+
+/* ---- payload structs (all little-endian, packed) ----------------------- */
+
+struct hvm_disp_hello {
+    uint32_t proto_version;       /* HVM_DISP_PROTO_VERSION */
+    uint32_t capability_flags;    /* see HVM_DISP_CAP_* */
+} __attribute__((packed));
+
+/* SURFACE_NEW: header.flags MUST include HVM_DISP_FLAG_HAS_FD;
+ * payload is followed in the same sendmsg(2) by exactly one SCM_RIGHTS fd
+ * referencing the framebuffer shm object. */
+struct hvm_disp_surface_new {
+    uint32_t width;
+    uint32_t height;
+    uint32_t stride;              /* bytes per row, may exceed width*bpp */
+    uint32_t format;              /* HVM_DISP_PIXFMT_* */
+    uint64_t shm_size;            /* mmap length in bytes */
+} __attribute__((packed));
+
+struct hvm_disp_surface_damage {
+    uint32_t x;
+    uint32_t y;
+    uint32_t w;
+    uint32_t h;
+} __attribute__((packed));
+
+/* CURSOR_DEFINE: payload struct followed by (width * height * 4) BGRA bytes
+ * (premultiplied alpha).  Spec caps width,height <= 256. */
+struct hvm_disp_cursor_define {
+    uint16_t width;
+    uint16_t height;
+    int16_t  hot_x;
+    int16_t  hot_y;
+    /* uint8_t pixels[width * height * 4]; */
+} __attribute__((packed));
+
+struct hvm_disp_cursor_pos {
+    int32_t  x;
+    int32_t  y;
+    uint32_t visible;             /* 0 = hidden, 1 = visible */
+} __attribute__((packed));
+
+struct hvm_disp_led_state {
+    uint32_t caps_lock;
+    uint32_t num_lock;
+    uint32_t scroll_lock;
+} __attribute__((packed));
+
+struct hvm_disp_resize_request {
+    uint32_t width;
+    uint32_t height;
+} __attribute__((packed));
+
+struct hvm_disp_goodbye {
+    uint32_t reason;              /* see HVM_DISP_GOODBYE_* */
+} __attribute__((packed));
+
+/* GOODBYE reason codes */
+#define HVM_DISP_GOODBYE_NORMAL            0u
+#define HVM_DISP_GOODBYE_VERSION_MISMATCH  1u
+#define HVM_DISP_GOODBYE_PROTOCOL_ERROR    2u
+#define HVM_DISP_GOODBYE_INTERNAL_ERROR    3u
+
+#endif /* HVM_DISPLAY_PROTO_H */
